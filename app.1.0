    tokenizer = nltk.data.load('tokenizers/punkt/english.pickle')
    stop_words = set(stopwords.words('english'))
    print("✓ Successfully loaded tokenizer and stopwords")
except Exception as e:
    print(f"ERROR: Failed to load NLTK components: {str(e)}")
    sys.exit(1)

# --- Model Loading ---
WHISPER_MODEL = None
TRANSLATOR = None

def load_models():
    """Load highly optimized models for CPU inference."""
    global WHISPER_MODEL, TRANSLATOR
    
    print(f"--- Loading Whisper model ({WHISPER_MODEL_SIZE} on {DEVICE}/{COMPUTE_TYPE})... ---")
    try:
        WHISPER_MODEL = WhisperModel(
            WHISPER_MODEL_SIZE, 
            device=DEVICE, 
            compute_type=COMPUTE_TYPE,
            local_files_only=False
        )
        print("✓ Whisper model loaded successfully.")
    except Exception as e:
        print(f"Error loading faster-whisper model: {e}", file=sys.stderr)

    # Smallest efficient translation model (MarianMT family: English-to-Spanish)
    # The React app asks to translate *to English*, so we load a reverse model (Spanish-to-English)
    # If the source language is known to be something else, the model name must be adjusted.
    TRANSLATION_MODEL_NAME = "Helsinki-NLP/opus-mt-es-en" 
    print(f"--- Loading Translation model ({TRANSLATION_MODEL_NAME})... ---")
    try:
        # MarianMT models are small and efficient seq2seq models
        TRANSLATOR = pipeline("translation", model=TRANSLATION_MODEL_NAME, device=DEVICE)
        print("✓ Translator model loaded successfully.")
    except Exception as e:
        print(f"Error loading translator model: {e}", file=sys.stderr)


# --- Flask App Initialization ---
app = Flask(__name__)
CORS(app)
load_models() # Load models once on startup


# --- Helper Functions (From CLI script) ---
def simple_sentence_tokenize(text):
    """Simple sentence tokenizer that doesn't rely on NLTK."""
    # Common sentence-ending punctuation
    endings = ['. ', '! ', '? ', '.\n', '!\n', '?\n']
    # Replace common abbreviations to avoid false splits
    abbreviations = {
        'Mr.': 'Mr_',
        'Mrs.': 'Mrs_',
        'Ms.': 'Ms_',
        'Dr.': 'Dr_',
        'Prof.': 'Prof_',
        'Sr.': 'Sr_',
        'Jr.': 'Jr_',
        'vs.': 'vs_',
        'e.g.': 'eg_',
        'i.e.': 'ie_',
        'etc.': 'etc_'
    }
    
    working_text = text
    # Temporarily replace abbreviations
    for abbr, repl in abbreviations.items():
        working_text = working_text.replace(abbr, repl)
    
    # Split into sentences
    for ending in endings:
        working_text = working_text.replace(ending, '\n')
    sentences = [s.strip() for s in working_text.split('\n') if s.strip()]
    
    # Restore abbreviations
    for abbr, repl in abbreviations.items():
        sentences = [s.replace(repl, abbr) for s in sentences]
    
    return sentences

def summarize_text_extractive(text, style="professional"):
    """Extractive summarization using simple frequency-based approach."""
    if not text or len(text.split()) < 20:
        return text

    # Define ratio based on desired style
    style_ratios = {
        'short': 0.15,
        'professional': 0.25,
        'long': 0.40,
        'bullet_points': 0.20,
        'report': 0.35
    }
    sentences_ratio = style_ratios.get(style.lower(), 0.25)
    
    # 1. Split into sentences using our simple tokenizer
    sentences = simple_sentence_tokenize(text)
    
    # 2. Calculate word frequencies (simple approach)
    words = text.lower().split()
    # Basic stopwords list
    basic_stopwords = {'a', 'an', 'and', 'are', 'as', 'at', 'be', 'by', 'for',
                      'from', 'has', 'he', 'in', 'is', 'it', 'its', 'of', 'on',
                      'that', 'the', 'to', 'was', 'were', 'will', 'with'}
    
    # Count word frequencies
    word_frequencies = {}
    for word in words:
        if word.isalnum() and word not in basic_stopwords:
            word_frequencies[word] = word_frequencies.get(word, 0) + 1

    # 3. Score sentences based on word frequencies
    sentence_scores = {}
    for sentence in sentences:
        score = 0
        words_in_sentence = sentence.lower().split()
        for word in words_in_sentence:
            if word in word_frequencies:
                score += word_frequencies[word]
        # Normalize by sentence length to avoid favoring long sentences too much
        sentence_scores[sentence] = score / (len(words_in_sentence) + 1)

    # 4. Get top N sentences
    num_sentences = max(1, int(len(sentences) * sentences_ratio))
    if num_sentences >= len(sentences):
        return text  # Return original text if summary would be too long

    # Sort sentences by score but maintain original order
    scored_sentences = [(sentence, sentence_scores[sentence]) for sentence in sentences]
    sorted_sentences = sorted(scored_sentences, key=lambda x: x[1], reverse=True)
    top_sentences = sorted_sentences[:num_sentences]
    
    # Reorder sentences to maintain original flow
    summary_sentences = []
    for sentence in sentences:
        if any(sentence == s[0] for s in top_sentences):
            summary_sentences.append(sentence)
            if len(summary_sentences) == num_sentences:
                break
    
    summary = " ".join(summary_sentences)
    
    # Format as bullet points if requested
    if style.lower() == "bullet_points":
        summary = "\n• " + "\n• ".join(summary_sentences)

    return summary

def format_timestamp(seconds):
    """Converts seconds to a HH:MM:SS string format."""
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    return f"{h:02d}:{m:02d}:{s:02d}"

