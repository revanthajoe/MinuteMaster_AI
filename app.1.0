@app.route('/health', methods=['GET'])
def health_check():
    """Health check endpoint to verify server status and essential components."""
    return jsonify({
        "status": "healthy",
        "uptime": int(time.time() - START_TIME),
        "models_loaded": {
            "whisper": WHISPER_MODEL is not None,
            "summarizer": True, # Extractive is always available
            "translator": TRANSLATOR is not None
        }
    })

@app.route('/transcribe', methods=['POST'])
def transcribe_audio_api():
    if 'audio' not in request.files:
        return jsonify({"error": "No audio file provided"}), 400

    if WHISPER_MODEL is None:
        return jsonify({"error": "Transcription model is not loaded"}), 503

    audio_file = request.files['audio']
    
    # Validate file extension
    allowed_extensions = {'.mp3', '.wav', '.m4a', '.ogg', '.flac', '.aac'}
    file_ext = os.path.splitext(audio_file.filename)[1].lower()
    if not file_ext:
        return jsonify({"error": "Audio file must have an extension"}), 400
    if file_ext not in allowed_extensions:
        return jsonify({"error": f"Unsupported file format. Allowed formats: {', '.join(allowed_extensions)}"}), 400

    # Create a unique directory to prevent conflicts
    unique_dir = tempfile.mkdtemp()
    temp_path = None
    wav_path = None

    try:
        # Verify FFmpeg is properly configured
        try:
            verify_ffmpeg()
        except Exception as e:
            raise RuntimeError(f"FFmpeg verification failed: {str(e)}")

        # 1. Save and validate the uploaded file
        temp_path = os.path.join(unique_dir, f"uploaded_audio{file_ext}")
        audio_file.save(temp_path)
        
        if not os.path.exists(temp_path):
            raise FileNotFoundError(f"Failed to save uploaded file to {temp_path}")
        
        if os.path.getsize(temp_path) == 0:
            raise ValueError("Uploaded file is empty")

        # 2. Process and validate the audio file
        wav_path = os.path.join(unique_dir, "processed_audio.wav")
        print(f"Processing audio file: {temp_path}")
        
        try:
            # Load the audio file
            audio = AudioSegment.from_file(temp_path)
            
            # Validate audio properties
            if len(audio) < 100:  # Less than 100ms
                raise ValueError("Audio file is too short")
            
            if len(audio) > 7200000:  # 2 hours
                raise ValueError("Audio file is too long (maximum 2 hours)")
            
            # Convert to format required by Whisper
            audio = audio.set_channels(1)  # Convert to mono
            audio = audio.set_frame_rate(16000)  # Convert to 16kHz
            
            # Export with specific parameters for Whisper
            audio.export(
                wav_path,
                format="wav",
                parameters=[
                    "-ac", "1",           # mono
                    "-ar", "16000",       # 16kHz
                    "-acodec", "pcm_s16le" # 16-bit PCM
                ]
            )
            
            # Verify the converted file
            if not os.path.exists(wav_path):
                raise FileNotFoundError("Failed to create converted WAV file")
            
            if os.path.getsize(wav_path) == 0:
                raise ValueError("Converted WAV file is empty")
                
        except Exception as e:
            raise RuntimeError(f"Audio processing failed: {str(e)}")
        
        if not os.path.exists(wav_path):
            raise FileNotFoundError(f"Failed to create WAV file at {wav_path}")

        # 3. Transcribe using faster-whisper
        segments, info = WHISPER_MODEL.transcribe(
            wav_path, 
            beam_size=5, 
            vad_filter=True 
        )
        
        # 4. Format the transcript
        # The language is now accessed as an attribute of info
        detected_language = getattr(info, 'language', 'en')
        
        transcript_segments = []
        for segment in segments:
            transcript_segments.append({
                "speaker": "Speaker",  # Placeholder, as faster-whisper base models don't diarize
                "time": format_timestamp(segment.start),
                "text": segment.text.strip() if segment.text else ""
            })
            
        if not transcript_segments:
             return jsonify({"error": "Could not transcribe any speech from the audio file."}), 400

        return jsonify({"transcript": transcript_segments, "language": detected_language})

    except Exception as e:
        error_msg = str(e)
        status_code = 500
        
        print(f"Error during transcription API: {error_msg}", file=sys.stderr)
        
        # Categorize errors and provide user-friendly messages
        if isinstance(e, (FileNotFoundError, OSError)):
            if "ffmpeg" in error_msg.lower():
                error_msg = "Audio processing failed. Please ensure FFmpeg is properly installed."
            else:
                error_msg = "Failed to process the audio file. Please try uploading again."
        elif isinstance(e, ValueError):
            status_code = 400
            error_msg = str(e)  # Value errors already have user-friendly messages
        elif isinstance(e, RuntimeError):
            if "ffmpeg" in error_msg.lower():
                error_msg = "Audio processing failed. Please ensure FFmpeg is properly installed."
            elif "whisper" in error_msg.lower():
                error_msg = "Speech recognition failed. Please try again with a different audio file."
            else:
                error_msg = f"Processing error: {str(e)}"
        else:
            error_msg = "An unexpected error occurred. Please try again or use a different audio file."
        
        return jsonify({"error": error_msg}), status_code

    finally:
        # Clean up temporary directory and files
        if unique_dir and os.path.exists(unique_dir):
             shutil.rmtree(unique_dir)
             print(f"--- Cleaned up temporary directory {unique_dir} ---")

@app.route('/summarize', methods=['POST'])
def summarize_text_api():
    data = request.get_json()
    
    if not data or 'transcript' not in data or 'style' not in data:
        return jsonify({"error": "Missing transcript or style in request"}), 400

    # Validate transcript data
    if not isinstance(data['transcript'], list):
        return jsonify({"error": "Transcript must be an array of segments"}), 400

    # Combine the transcript text into a single block
    try:
        full_transcript_text = " ".join([item['text'] for item in data['transcript'] if isinstance(item, dict) and 'text' in item])
    except Exception as e:
        return jsonify({"error": "Invalid transcript format"}), 400

    if not full_transcript_text.strip():
        return jsonify({"error": "No valid text found in transcript"}), 400

    style = data['style']
    
    try:
        summary = summarize_text_extractive(full_transcript_text, style=style)
        
        if not summary:
            return jsonify({"error": "The input text was too short to summarize."}), 400

        return jsonify({"summary": summary})

    except Exception as e:
        print(f"Error during summarization API: {str(e)}", file=sys.stderr)
        return jsonify({"error": "Failed to generate summary. Please try again."}), 500
        
@app.route('/translate', methods=['POST'])
def translate_text_api():
    data = request.get_json()
    
    if not data or 'text' not in data or 'target_language' not in data or 'source_language' not in data:
        return jsonify({"error": "Missing text, source_language, or target_language in request"}), 400

    if TRANSLATOR is None:
        return jsonify({"error": "Translation model not loaded. Check server console for errors."}), 503

    text_to_translate = data['text']
    # The React frontend explicitly requests translation TO 'English'.
    # We loaded the Spanish-to-English model (opus-mt-es-en) for demonstration.
    
    # We need to ensure the source language is compatible with the loaded model.
    # In a real-world app, you'd dynamically load the correct model for the source language.
    # Since we loaded 'es-en', we'll assume a non-English input is Spanish for now.
    source_language_code = 'es' 
    target_language_code = 'en'
    
    try:
        # We assume the summary is in Spanish (source_language_code) and translate to English (target_language_code).
        # Note: If the actual source language detected by Whisper is NOT Spanish, this translation will be poor.
        
        # Truncate for efficiency on the small model
        if len(text_to_translate.split()) > 200:
             text_to_translate = " ".join(text_to_translate.split()[:200])
             print("Warning: Input text truncated for efficient translation.")

        translated_result = TRANSLATOR(text_to_translate)
        translated_text = translated_result[0]['translation_text']
        
        return jsonify({"translated_text": translated_text})
        
    except Exception as e:
        print(f"Error during translation API: {e}", file=sys.stderr)
        return jsonify({"error": f"Failed to translate text: {e}"}), 500


if __name__ == '__main__':
    app.run(host='127.0.0.1', port=5000)
