# --- CONFIGURE FFmpeg/AudioSegment ---
# Set FFmpeg path and verify executables
FFMPEG_PATH = r"C:\ffmpeg-master-latest-win64-gpl-shared\bin"
FFMPEG_EXE = os.path.join(FFMPEG_PATH, 'ffmpeg.exe')
FFPROBE_EXE = os.path.join(FFMPEG_PATH, 'ffprobe.exe')

def verify_ffmpeg():
    """Verify FFmpeg installation and configuration."""
    if not os.path.exists(FFMPEG_PATH):
        raise RuntimeError(f"FFmpeg directory not found at: {FFMPEG_PATH}")
    
    if not os.path.exists(FFMPEG_EXE):
        raise RuntimeError(f"ffmpeg.exe not found at: {FFMPEG_EXE}")
    
    if not os.path.exists(FFPROBE_EXE):
        raise RuntimeError(f"ffprobe.exe not found at: {FFPROBE_EXE}")
    
    # Add FFmpeg to system PATH for this session
    if FFMPEG_PATH not in os.environ['PATH']:
        os.environ['PATH'] = FFMPEG_PATH + os.pathsep + os.environ['PATH']
    
    # Configure pydub
    from pydub import AudioSegment
    AudioSegment.converter = FFMPEG_EXE
    AudioSegment.ffprobe = FFPROBE_EXE
    
    print("✓ FFmpeg configured successfully:")
    print(f"  - Directory: {FFMPEG_PATH}")
    print(f"  - FFmpeg: {FFMPEG_EXE}")
    print(f"  - FFprobe: {FFPROBE_EXE}")

# Verify FFmpeg on startup
try:
    verify_ffmpeg()
except Exception as e:
    print(f"ERROR: FFmpeg configuration failed: {str(e)}")
    print("Please ensure FFmpeg is properly installed and the path is correct.")
    sys.exit(1)

# --- Configuration for Low-End Efficiency ---
WHISPER_MODEL_SIZE = "tiny.en" # Use "tiny" for multilingual, "tiny.en" for English-only
DEVICE = "cpu"
COMPUTE_TYPE = "int8" # 8-bit quantization for maximum CPU speed and minimum RAM usage
START_TIME = time.time()

# Initialize NLTK resources
def initialize_nltk():
    """Initialize and verify NLTK resources."""
    required_resources = {
        'tokenizers/punkt': 'punkt',
        'corpora/stopwords': 'stopwords'
    }
    
    for resource_path, resource_name in required_resources.items():
        try:
            # First try to load the resource
            nltk.data.find(resource_path)
            print(f"✓ Found NLTK resource: {resource_name}")
        except LookupError:
            # If not found, download it
            print(f"Downloading NLTK resource: {resource_name}")
            nltk.download(resource_name, quiet=True)
            # Verify the download
            try:
                nltk.data.find(resource_path)
                print(f"✓ Successfully downloaded and verified: {resource_name}")
            except LookupError as e:
                print(f"ERROR: Failed to download {resource_name}: {str(e)}")
                sys.exit(1)

# Initialize NLTK resources on startup
print("--- Initializing NLTK resources... ---")
initialize_nltk()
print("--- NLTK initialization completed ---")

# Pre-load the tokenizer and stopwords to verify they work
